# Discord
TOKEN=                     # bot token used to log in
DISCORD_TOKEN=             # same value as TOKEN (some modules read this name)
CLIENT_ID=                 # application (client) id, needed to register slash commands

# Database (new - required by both the package system and order logging system)
MONGODB_URI=               # e.g. mongodb+srv://user:pass@cluster.mongodb.net/nugget

# Roblox <-> Discord account linking (Docksys) - replaces the old BLOXLINK_API_KEY
DOCKSYS_API_KEY=           # from https://docksys.xyz/account - your server must have the Docksys bot added

# Roblox group session - used ONLY by the order logging system to read the
# group's real transaction/payout log for cross-verification. This is the
# same env var the old package system's purchase watcher used.
ROBLOX_COOKIE=             # .ROBLOSECURITY cookie of an account with permission to view group payouts

# Optional: where package download files are cached on disk. Point this at a
# persistent volume (e.g. Railway volume) or files will be lost on redeploy.
PACKAGE_FILES_DIR=data/packages/downloads
